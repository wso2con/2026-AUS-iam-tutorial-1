# Port used by the MCP server.
MCP_PORT=8000

# Host used by the MCP server.
HOST=localhost

# Base URL of the Wayfinder Travel REST API.
API_BASE_URL=http://localhost:8787

# Required for the CIBA better-deal tool.
ASGARDEO_BASE_URL=https://api.asgardeo.io/t/your-organization-name
CIBA_CLIENT_ID=your-ciba-enabled-application-client-id
CIBA_CLIENT_SECRET=your-ciba-enabled-application-client-secret
CIBA_SCOPE=openid profile
CIBA_NOTIFICATION_CHANNEL=email

# Optional: include the agent bearer token as actor_token in the CIBA request.
CIBA_INCLUDE_ACTOR_TOKEN=false
# Optional: log the CIBA auth_url returned for external/manual approval debugging.
CIBA_LOG_AUTH_URL=false
CIBA_POLL_INTERVAL_SECONDS=3
CIBA_POLL_TIMEOUT_MS=120000
