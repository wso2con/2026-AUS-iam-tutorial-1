# Agent Server Configuration

# Asgardeo base URL (tenant URL)
ASGARDEO_BASE_URL=https://api.asgardeo.io/t/<tenant>

# MCP Client Application's Client ID and Secret
ASGARDEO_CLIENT_ID=<mcp-client-app-client-id>
ASGARDEO_CLIENT_SECRET=<mcp-client-app-client-secret>

# Agent credentials (from Asgardeo Console > Agents)
AGENT_ID=<agent-id>
AGENT_SECRET=<agent-secret>

# Optional resource parameter for the agent token request (for example, booking_api)
AGENT_RESOURCE=

# SPA Application's Client ID (used as JWT audience)
TOKEN_AUDIENCE=<spa-app-client-id>

# JWT validation
JWKS_URL=https://api.asgardeo.io/t/<tenant>/oauth2/jwks
AUTH_ISSUER=https://api.asgardeo.io/t/<tenant>/oauth2/token

# OBO callback URI (must match Asgardeo app redirect URI)
OBO_REDIRECT_URI=http://localhost:5001/api/obo/callback

# LLM configuration
GOOGLE_API_KEY=<google-ai-studio-key>
MODEL_NAME=gemini-2.5-flash

# WAYFINDER MCP Server URL
WAYFINDER_MCP_SERVER_URL=http://localhost:8000/mcp

# Set to "true" to disable SSL verification (dev only)
DISABLE_SSL_VERIFY=false

# Optional CORS controls for the agent API.
# Localhost/127.0.0.1 on any port are allowed by default for local frontend dev.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Space-separated scopes requested for the agent's own access token.
AGENT_SCOPES=openid profile bookings:read

# Optional space-separated scopes requested when the user authorizes the agent to act on their behalf.
OBO_SCOPES=openid profile bookings:write

# Resource parameter used when exchanging the OBO authorization code for a token.
OBO_RESOURCE=booking_api
