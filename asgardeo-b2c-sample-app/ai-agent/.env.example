# Client ID of the agent application associated with the created AI agent in Asgardeo
CLIENT_ID=client ID of the agent application

# Client secret of the agent application associated with the created AI agent in Asgardeo
CLIENT_SECRET=client secret of the agent application

# Base URL of your Asgardeo organization.
ASGARDEO_BASE_URL=https://api.asgardeo.io/t/<your organization>

# Space-separated scopes requested for the agent's own access token.
# Include the Wayfinder API scopes the agent needs so Asgardeo adds the API audience to the token.
AGENT_SCOPES=openid profile bookings:read deal-alert-consents:write

# Redirect URI configured for the Asgardeo application.
REDIRECT_URI=http://localhost:8790

# Redirect URI configured for redirect-based on-behalf-of authorization.
OBO_REDIRECT_URI=http://localhost:8790/oauth/callback

# Optional space-separated scopes requested when the user authorizes the agent to act on their behalf.
OBO_SCOPES=openid profile profile:read bookings:read bookings:write

# Agent identifier issued by Asgardeo.
AGENT_ID=agent ID of the agent created in Asgardeo

# Agent secret issued by Asgardeo.
AGENT_SECRET=agent secret of the agent created in Asgardeo

# API key used by the Gemini chat model.
GOOGLE_API_KEY=your google API key

# Gemini model used by the agent.
MODEL_NAME=gemini-2.5-flash

# MCP server endpoint used by the agent.
MCP_SERVER_URL=http://localhost:8000/mcp

# Port used by the agent WebSocket server.
AGENT_PORT=8790

# Host used by the agent WebSocket server.
HOST=localhost

# Structured log level used by pino.
LOG_LEVEL=info
